{
  "name": "quantumswap-web-app",
  "private": true,
  "version": "0.1.0-beta",
  "type": "module",
  "description": "QuantumSwap Web App (Beta/Test Version) - a decentralized exchange front end for the QuantumCoin network.",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint . --max-warnings 0",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install --with-deps chromium",
    "check:naming": "node scripts/check-naming.mjs"
  },
  "dependencies": {
    "@fontsource/inter": "^5.2.8",
    "@fontsource/space-grotesk": "^5.2.10",
    "quantumcoin": "^8.0.2",
    "quantumswap": "^1.0.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^20.16.11",
    "@typescript-eslint/eslint-plugin": "^8.8.0",
    "@typescript-eslint/parser": "^8.8.0",
    "eslint": "^8.57.1",
    "jsdom": "^25.0.1",
    "typescript": "^5.6.2",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=20"
  }
}
